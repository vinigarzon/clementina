# =====================================================================
# Variables de entorno de Finca La Clementina
# Copia este archivo a `.env.local` y llena tus credenciales reales.
# NUNCA commitees `.env.local`. Solo este `.env.example` con valores vacíos.
# =====================================================================

# --- Supabase ---
# Project Settings → API en tu proyecto Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
# URL pública del sitio. En producción Netlify: https://tu-dominio.com
# Se usa para construir URLs absolutas (favicons, logo en emails, OG tags).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Resend (envío de emails) ---
# https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXX
# Estas dos pueden editarse desde /admin/configuracion una vez aplicada
# la migración 0009. Quedan como fallback inicial.
RESEND_FROM_EMAIL=clementina@gurumba.com
RESEND_FROM_NAME=Finca La Clementina

# A dónde llegan los correos cuando alguien llena el form de contacto.
# Editable desde /admin/configuracion. Esta env queda como fallback.
LEAD_NOTIFICATION_EMAIL=info@fincalaclementina.com

# --- Google Analytics 4 ---
# Opcional. https://analytics.google.com → Property settings.
NEXT_PUBLIC_GA4_ID=

# --- reCAPTCHA v3 ---
# Opcional. https://www.google.com/recaptcha/admin
# Si no se setea, el form no valida captcha (útil en dev).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
